<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Health Connect permissions -->
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_HEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BASAL_METABOLIC_RATE" />
    <uses-permission android:name="android.permission.health.READ_BONE_MASS" />
    <uses-permission android:name="android.permission.health.READ_LEAN_BODY_MASS" />

    <!-- Declare that this app queries Health Connect -->
    <queries>
        <!-- Android 14+ (API 34+): HC is built into the framework, served by this package -->
        <package android:name="com.google.android.healthconnect.controller" />
        <!-- Fallback for older standalone HC app installs (API 28-33) -->
        <package android:name="com.google.android.apps.healthdata" />
        <!-- Intent-based query covers any future resolution changes -->
        <intent>
            <action android:name="android.health.connect.action.REQUEST_HEALTH_PERMISSIONS" />
        </intent>
    </queries>

    <application
        android:name=".PowerMeApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PowerME">
        <service
            android:name=".util.WorkoutTimerService"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.PowerME.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".health.PermissionsRationaleActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
            <meta-data
                android:name="health_permissions"
                android:resource="@xml/health_permissions" />
        </activity>

        <!-- Android 14+ (API 34+) framework Health Connect rationale entrypoint.
             com.google.android.healthconnect.controller resolves this alias to render
             the "Privacy policy" link in the permission sheet and to validate that the
             app is HC-compliant before showing the dialog. Without it, the framework
             controller short-circuits the permission request and returns 0 granted in ~93ms.
             Protected by START_VIEW_PERMISSION_USAGE so only the system can launch it.
             The androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE filter above covers
             Android 13 / standalone HC APK (com.google.android.apps.healthdata). -->
        <activity-alias
            android:name=".health.ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".health.PermissionsRationaleActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>