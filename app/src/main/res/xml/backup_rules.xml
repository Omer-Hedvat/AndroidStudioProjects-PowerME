<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <!-- Exclude the DataStore prefs file so the Firestore restore gate flag
         (has_restored_once) is never carried over to a fresh install.
         Room DB is already excluded from backup by the system (too large). -->
    <exclude domain="file" path="datastore/app_settings.preferences_pb" />
</full-backup-content>